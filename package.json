  "main": "app/background.js",
  "scripts": {
    "dev": "chcp 65001 >nul && nextron",
    "build": "nextron build",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "npm --prefix perssuavatar-web run typecheck",
    "typecheck:all": "npm run typecheck && npm run typecheck:web",
    "postinstall": "node scripts/postinstall-native.cjs",
    "rebuild:sqlite": "npm rebuild sqlite3 --verbose",
    "remotion:studio": "npx remotion studio remotion/index.ts",
    "remotion:render": "npx remotion render remotion/index.ts --gl=angle",
    "embeddings:generate": "tsx main/generate-embeddings.ts",
    "embeddings:folder": "tsx main/generate-embeddings.ts --from-folder",
    "embeddings:from-supabase": "tsx main/generate-embeddings.ts --from-supabase"
  },
